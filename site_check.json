dth=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar text-champagne\" aria-hidden=\"true\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg></div><h3 class=\"font-sans text-xl font-bold text-obsidian\">Гарантия результата</h3></div><p class=\"text-slate text-sm mb-6 leading-relaxed\">Страховка имущества и бесплатный доклинг при необходимости</p><div class=\"bg-white rounded-2xl p-4 flex-1\"><div class=\"grid grid-cols-7 gap-2 mb-4\"><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">С</div><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">П</div><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">В</div><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">С</div><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">Ч</div><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">П</div><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">Ш</div><div class=\"aspect-square rounded-xl flex items-center justify-center font-mono text-sm transition-all duration-300 bg-obsidian/5 text-slate\">В</div></div><div class=\"flex items-center justify-between\"><span class=\"font-mono text-xs text-slate\">Ближайший слот: зав